# Position the hud in the top-right corner
position=top-right
# Make the dark background completely invisible
background_alpha=0.0

# Remove the default spacing box around the text
round_corners=0

# Snap the counter closer to the screen edges (adjust down if needed)offset_y=-7


# Disable all default resource tracking
cpu_stats=0
gpu_stats=0
ram=0
vram=0
battery=0
frame_timing=0

# Enable ONLY the FPS counter
fps=1
fps_only=1

# Change the text color to Green (Hex code for pure green)
text_color=00FF00
